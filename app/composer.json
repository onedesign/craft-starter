{
  "require": {
    "craftcms/ckeditor": "^5.6.1",
    "craftcms/cms": "^5.10",
    "nystudio107/craft-seomatic": "^5.1.21",
    "nystudio107/craft-typogrify": "^5.0.3",
    "putyourlightson/craft-sherlock": "^5.2",
    "servd/craft-asset-storage": "^4.2",
    "spacecatninja/imager-x": "^6.0.0",
    "verbb/formie": "^3.1",
    "verbb/hyper": "^2.3.7",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "require-dev": {
    "craftcms/generator": "^2.0.0",
    "nystudio107/craft-autocomplete": "^1.11",
    "roave/security-advisories": "dev-latest",
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "modules\\": "modules/"
    }
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.2"
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
