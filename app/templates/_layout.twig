{% include '_partials/vite' ignore missing %}
{% import '_partials/vite' as vite %}

{# --------------------------------------------------------- #}
{# Layout
{# --------------------------------------------------------- #}
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="{{ craft.app.language }}" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="{{ vite.url('/images/favicon.svg') }}" />
    <link rel="icon" href="{{ vite.url('/images/favicon.ico') }}" />

    {# Ensure Analytics don't use cookies by default #}
    {# prettier-ignore-start #}
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
          dataLayer.push(arguments);
      }
      gtag("consent", "default", {
        ad_storage: "denied",
        ad_user_data: "denied", 
        ad_personalization: "denied",
        analytics_storage: "denied",
        functionality_storage: "denied",
        personalization_storage: "denied",
        security_storage: "granted",
        wait_for_update: 2000,
      });
      gtag("set", "ads_data_redaction", true);
      gtag("set", "url_passthrough", true);
    </script>
    {# prettier-ignore-end #}

    {# Insert CookieYes script here #}

    {# Render SEOmatic tags #}
    {% hook 'seomaticRender' %}
  </head>

  <body>
    <main id="main-content" tabindex="-1">
      <header>
        <a class="skip-link" href="#main-content">Skip to content</a>
      </header>

      {% block content %}

      {% endblock %}
    </main>
  </body>
</html>
